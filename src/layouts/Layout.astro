---
import 'bootstrap/dist/css/bootstrap.min.css';
import '../styles/app.css';
import { Image } from 'astro:assets';
import logo from '../assets/strichliste-logo.png';
import { NAV_ITEMS, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

interface Props {
  /** Page title; omit on the homepage to use the full site title. */
  title?: string;
  description?: string;
}

const { title, description = SITE_DESCRIPTION } = Astro.props;

const pathname = Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;

const isCurrent = (href: string) => href === pathname;
const isAncestor = (href: string) =>
  href.startsWith('/') && href !== '/' && !isCurrent(href) && pathname.startsWith(href);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title ? `${title} · strichliste` : SITE_TITLE}</title>
    <meta name="description" content={description} />
    <link
      rel="alternate"
      type="application/rss+xml"
      href={new URL('index.xml', Astro.site)}
      title={SITE_TITLE}
    />

    <link rel="icon" sizes="128x128" href="/img/common/logo-touch-icon.png" />

    <script is:inline>
      // Marker for progressive enhancement: the burger menu only collapses
      // the nav when scripting is available; without JS the nav stays open.
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body>
    <a class="visually-hidden-focusable p-2" href="#main">Skip to main content</a>
    <header class="header container d-flex justify-content-between align-items-end flex-wrap">
      <a class="logo" href="/">
        <Image src={logo} alt="strichliste — home" loading="eager" />
      </a>
      <nav aria-label="Main" class="site-nav">
        <button type="button" class="nav-toggle" aria-expanded="false" aria-controls="site-menu">
          <span class="nav-toggle-icon" aria-hidden="true"></span>
          Menu
        </button>
        <ul class="nav" id="site-menu" role="list">
          {
            NAV_ITEMS.map((item) => (
              <li class:list={{ active: isCurrent(item.href) || isAncestor(item.href) }}>
                <a
                  href={item.href}
                  aria-current={
                    isCurrent(item.href) ? 'page' : isAncestor(item.href) ? 'true' : undefined
                  }
                >
                  {item.name}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </header>
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <footer class="footer">
      <div class="container">
        <p>
          strichliste is <a href="https://github.com/strichliste">open source on GitHub</a> (MIT
          license) · <a href="/news/">News</a> · <a href="/index.xml">RSS feed</a>
        </p>
      </div>
    </footer>

    <script>
      const toggle = document.querySelector('.nav-toggle');
      const nav = toggle?.closest('nav');
      if (toggle && nav) {
        toggle.addEventListener('click', () => {
          const open = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', String(!open));
        });
        nav.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
            toggle.setAttribute('aria-expanded', 'false');
            (toggle as HTMLElement).focus();
          }
        });
      }
    </script>
  </body>
</html>
