---
import 'bootstrap/dist/css/bootstrap.min.css';
import '../styles/app.css';
import { Image } from 'astro:assets';
import logo from '../assets/strichliste-logo.png';
import { NAV_ITEMS, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

interface Props {
  /** Page title; omit on the homepage to use the full site title. */
  title?: string;
  description?: string;
}

const { title, description = SITE_DESCRIPTION } = Astro.props;

const pathname = Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;

const isCurrent = (href: string) => href === pathname;
const isAncestor = (href: string) =>
  href.startsWith('/') && href !== '/' && !isCurrent(href) && pathname.startsWith(href);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title ? `${title} · strichliste` : SITE_TITLE}</title>
    <meta name="description" content={description} />
    <link
      rel="alternate"
      type="application/rss+xml"
      href={new URL('index.xml', Astro.site)}
      title={SITE_TITLE}
    />

    <link rel="icon" sizes="128x128" href="/img/common/logo-touch-icon.png" />
  </head>
  <body>
    <a class="visually-hidden-focusable p-2" href="#main">Skip to main content</a>
    <header class="header container d-flex justify-content-between align-items-end flex-wrap">
      <a class="logo" href="/">
        <Image src={logo} alt="strichliste — home" loading="eager" />
      </a>
      <nav aria-label="Main">
        <ul class="nav" role="list">
          {
            NAV_ITEMS.map((item) => (
              <li class:list={{ active: isCurrent(item.href) || isAncestor(item.href) }}>
                <a
                  href={item.href}
                  aria-current={
                    isCurrent(item.href) ? 'page' : isAncestor(item.href) ? 'true' : undefined
                  }
                >
                  {item.name}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </header>
    <main id="main" tabindex="-1">
      <slot />
    </main>
  </body>
</html>
